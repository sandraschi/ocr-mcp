# OCR-MCP Configuration
# Copy to .env and modify as needed

# OCR Backend Settings
OCR_CACHE_DIR=~/.cache/ocr-mcp
OCR_DEVICE=auto
OCR_DEFAULT_BACKEND=unlimited-ocr

# Mistral OCR (optional - cloud API)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Tesseract (optional - override PATH)
TESSERACT_CMD=

# Poppler (optional - PDF rendering)
POPPLER_PATH=

# Sampling (optional - for agentic workflows)
OCR_SAMPLING_USE_CLIENT_LLM=0
OCR_SAMPLING_BASE_URL=http://127.0.0.1:11434/v1
OCR_SAMPLING_MODEL=llama3.2

# Webapp Ports
WEB_PORT=10858
BACKEND_PORT=10859
