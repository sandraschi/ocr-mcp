{
    "name": "ocr-mcp",
    "version": "1.0.0",
    "type": "server",
    "runtime": "python",
    "entry_point": "src/ocr_mcp/server.py",
    "dependencies": [
        "fastmcp>=3.1",
        "pytesseract>=0.3.10"
    ],
    "build": {
        "include": [
            "src/**/*",
            "README.md",
            "LICENSE"
        ],
        "exclude": [
            "tests/",
            ".git/",
            "__pycache__/",
            "*.pyc",
            ".venv/",
            "dist/",
            "build/",
            "target/",
            "docs/",
            "scripts/"
        ]
    },
    "scripts": {
        "build": "mcpb build",
        "pack": "mcpb pack . dist/ocr-mcp.mcpb",
        "test": "python -m pytest"
    }
}