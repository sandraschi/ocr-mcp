{
    "name": "ocr-mcp",
    "version": "1.0.0",
    "type": "server",
    "runtime": "python",
    "entry_point": "src/ocr_mcp/server.py",
    "dependencies": [
        "fastmcp>=3.1",
        "pydantic>=2.0.0",
        "python-dotenv>=1.0.0",
        "pillow>=10.0.0",
        "opencv-python>=4.8.0",
        "pytesseract>=0.3.10",
        "easyocr>=1.7.0",
        "fastapi>=0.115.0",
        "uvicorn[standard]>=0.35.0",
        "python-multipart>=0.0.9",
        "aiohttp>=3.9.0",
        "structlog>=23.0.0",
        "pymupdf>=1.23.0",
        "pypdf>=3.17.0",
        "pdf2image>=1.17.0"
    ],
    "build": {
        "include": [
            "src/**/*",
            "README.md",
            "LICENSE"
        ],
        "exclude": [
            "tests/",
            ".git/",
            "__pycache__/",
            "*.pyc",
            ".venv/",
            "dist/",
            "build/",
            "target/",
            "docs/",
            "scripts/"
        ]
    },
    "scripts": {
        "build": "mcpb build",
        "pack": "mcpb pack . dist/ocr-mcp.mcpb",
        "test": "python -m pytest"
    }
}