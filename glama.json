{
  "mcpServers": {
    "ocr-mcp": {
      "name": "ocr-mcp",
      "command": "uv",
      "args": ["--directory", "${workspaceFolder}", "run", "ocr-mcp"],
      "env": {},
      "description": "FastMCP 3.1 document OCR server: 10+ SOTA backends (PaddleOCR-VL-1.5, DeepSeek-OCR-2, olmOCR-2, etc.), sampling, agentic workflow (SEP-1577), prompts, skills resource. WIA scanner (Windows). React web UI.",
      "capabilities": {
        "webapp": {
          "enabled": true,
          "url": "http://localhost:15550"
        },
        "sampling": true,
        "ai_features": {
          "enabled": true,
          "notes": "Sampling + agentic_document_workflow. SOTA OCR needs GPU (RTX 3060+). Optional Ollama/LM Studio for semantic analysis."
        },
        "tools": {
          "enabled": true,
          "listChanged": true
        },
        "resources": {
          "enabled": true,
          "listChanged": true,
          "subscribe": true
        },
        "prompts": {
          "enabled": true
        }
      },
      "timeout": {
        "initialize": 30000,
        "message": 60000
      },
      "metadata": {
        "version": "0.2.0",
        "author": "Sandra Schipal",
        "homepage": "https://github.com/sandraschi/ocr-mcp",
        "license": "MIT",
        "stars": "GitHub stars welcome — repo has 7+",
        "tags": [
          "ocr",
          "document-processing",
          "fastmcp-3.1",
          "sampling",
          "agentic",
          "sep-1577",
          "computer-vision",
          "pdf",
          "scanner",
          "wia"
        ],
        "categories": [
          "Productivity",
          "AI/ML",
          "Document Processing",
          "Web Applications"
        ]
      }
    }
  }
}